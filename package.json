{
  "name": "sklock",
  "version": "0.1.0",
  "description": "A lockfile and graph manager for recursive AI agent skills.",
  "type": "module",
  "bin": {
    "sklock": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format esm --dts",
    "prepare": "npm run build",
    "dev": "tsx src/cli.ts",
    "check": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "fast-glob": "^3.3.3",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
