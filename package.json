{
  "name": "sklock",
  "version": "0.2.2",
  "description": "A lockfile and graph manager for recursive AI agent skills.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "sklock": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/artieax/sklock.git"
  },
  "bugs": {
    "url": "https://github.com/artieax/sklock/issues"
  },
  "homepage": "https://github.com/artieax/sklock#readme",
  "keywords": [
    "agent-skills",
    "ai-agents",
    "skills",
    "lockfile",
    "dependency-graph",
    "cli"
  ],
  "files": [
    "dist",
    "schemas",
    "skills",
    "scripts/post-install.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "postinstall": "node scripts/post-install.mjs",
    "build": "tsup src/cli.ts src/index.ts --format esm --dts --clean",
    "json-schema": "tsx scripts/generate-skill-json-schema.ts",
    "prepublishOnly": "npm run check && npm test && npm run build && npm run json-schema",
    "prepare": "npm run build",
    "dev": "tsx src/cli.ts",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "fast-glob": "^3.3.3",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.2",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "license": "Apache-2.0"
}
